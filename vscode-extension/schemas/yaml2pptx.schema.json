      "description": "Content slide - the default/fallback slide type for general content.",
      "markdownDescription": "**Content** slide (default/fallback). A flexible slide type that supports text content (string or bullet points), images, and tables. Used when no specific slide type is needed.",
      "properties": {
        "type": {
          "type": "string",
          "const": "content",
          "description": "Slide type: content (default/fallback)"
        },
        "title": {
          "type": "string",
          "description": "Slide title."
        },
